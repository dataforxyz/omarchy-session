import json
import os
import re
import shlex
import shutil
import sqlite3
import subprocess
import sys
import time
from collections import Counter
from pathlib import Path
from urllib.parse import urlparse

STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "omarchy-session"
SESSION_FILE = STATE_DIR / "last-session.json"
UNDO_FILE = STATE_DIR / "before-last-restore.json"
LAST_RESTORE_FILE = STATE_DIR / "last-restore.json"
AUTOSAVE_DIR = STATE_DIR / "autosaves"
LATEST_AUTOSAVE = AUTOSAVE_DIR / "latest.json"
PROFILE_DIR = STATE_DIR / "profiles"
AUTOSAVE_KEEP = 48
PI_SESSION_ROOT = Path.home() / ".pi/agent/sessions"
CLAUDE_PROJECT_ROOT = Path.home() / ".claude/projects"
CLAUDE_ALIAS_COMMANDS = {"clo", "clod", "cloc"}
CLAUDE_ALIAS_CONFIGS = {
    "deepseek": "clod",
    "cliproxy": "cloc",
}
CODEX_SESSION_ROOT = Path.home() / ".codex/sessions"
OPENCODE_DB = Path.home() / ".local/share/opencode/opencode.db"
MAKE_RESTORE_TARGETS = {"ssh", "pi", "claude", "clo", "clod", "cloc", "codex", "opencode"}
DIRECT_RESTORE_COMMANDS = {"ssh", "tmux", "claude", "clo", "clod", "cloc", "codex", "opencode"}
EXCLUDED_CLASSES = {"zenity", "pinentry", "org.gnome.polkit", "xdg-desktop-portal"}
SINGLETON_CLASSES = {
    "chromium", "chromium-browser", "brave-browser", "brave",
    "google-chrome", "google-chrome-stable", "firefox", "firefoxdeveloperedition",
    "slack", "discord", "signal", "signal-desktop", "obsidian", "thunderbird", "keepassxc",
    "org.keepassxc.keepassxc",
}
TERMINAL_CLASSES = {"com.mitchellh.ghostty", "ghostty", "alacritty"}
REQUIRED_COMMANDS = ("hyprctl",)
VERBOSE = False

OPTIONAL_COMMAND_GROUPS = {
    "terminal restore": ("ghostty", "alacritty"),
    "notifications/session supervision": ("notify-send", "uwsm"),
    "pick menu": ("walker", "wofi", "fuzzel", "rofi"),
    "web apps": ("omarchy-launch-webapp",),
    "app restore targets": (
        "chromium", "brave", "google-chrome-stable", "firefox", "obsidian", "slack",
        "discord", "signal-desktop", "nautilus", "thunderbird", "keepassxc", "code",
    ),
    "agent resume helpers": ("pi", "claude", "clo", "clod", "cloc", "codex", "opencode"),
}


def notify(title: str, body: str = "") -> None:
    if shutil.which("notify-send"):
        subprocess.run(["notify-send", title, body], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def require(cmd: str) -> None:
    if not shutil.which(cmd):
        print(f"Missing required command: {cmd}", file=sys.stderr)
        sys.exit(1)


def dependency_status() -> None:
    print("Omarchy session dependencies")
    print(f"  python: {sys.version.split()[0]} ({sys.executable})")

    missing_required = []
    for cmd in REQUIRED_COMMANDS:
        path = shutil.which(cmd)
        if path:
            print(f"  required: {cmd:<24} ok ({path})")
        else:
            print(f"  required: {cmd:<24} missing")
            missing_required.append(cmd)

    for group, commands in OPTIONAL_COMMAND_GROUPS.items():
        present = [cmd for cmd in commands if shutil.which(cmd)]
        missing = [cmd for cmd in commands if not shutil.which(cmd)]
        present_text = ", ".join(present) if present else "none"
        missing_text = ", ".join(missing) if missing else "none"
        print(f"  optional: {group:<24} present: {present_text}; missing: {missing_text}")

    if missing_required:
        print("\nMissing required commands prevent save/restore from reading Hyprland state.", file=sys.stderr)
        sys.exit(1)


def read_proc_argv(pid: int) -> list[str]:
    try:
        raw = Path(f"/proc/{pid}/cmdline").read_bytes()
        return [part.decode(errors="replace") for part in raw.split(b"\0") if part]
    except Exception:
        return []


def read_proc_environ(pid: int) -> dict[str, str]:
    try:
        raw = Path(f"/proc/{pid}/environ").read_bytes()
    except Exception:
        return {}
    env: dict[str, str] = {}
    for part in raw.split(b"\0"):
        if b"=" not in part:
            continue
        key, value = part.split(b"=", 1)
        env[key.decode(errors="replace")] = value.decode(errors="replace")
    return env


def read_proc_cwd(pid: int) -> str:
    try:
        return str(Path(f"/proc/{pid}/cwd").resolve())
    except Exception:
        return ""


def proc_info(pid: int) -> tuple[str, str, str, list[str]]:
    cwd = ""
    cmdline = ""
    workdir = ""
    argv: list[str] = []

    cwd = read_proc_cwd(pid)
    argv = read_proc_argv(pid)
    cmdline = " ".join(shlex.quote(part) for part in argv)

    parts = argv or shlex.split(cmdline)
    for i, part in enumerate(parts):
        if part.startswith("--working-directory="):
            workdir = part.split("=", 1)[1]
            break
        if part == "--working-directory" and i + 1 < len(parts):
            workdir = parts[i + 1]
            break

    workdir = workdir.strip("'\"") or cwd
    return cwd, cmdline, workdir, argv


def child_map() -> dict[int, list[int]]:
    children: dict[int, list[int]] = {}
    for proc in Path("/proc").iterdir():
        if not proc.name.isdigit():
            continue
        try:
            pid = int(proc.name)
            for line in (proc / "status").read_text(errors="ignore").splitlines():
                if line.startswith("PPid:"):
                    ppid = int(line.split()[1])
                    children.setdefault(ppid, []).append(pid)
                    break
        except Exception:
            continue
    return children


def descendants(pid: int, children: dict[int, list[int]]) -> list[tuple[int, int]]:
    found: list[tuple[int, int]] = []
    stack = [(child, 1) for child in children.get(pid, [])]
    while stack:
        child, depth = stack.pop()
        found.append((child, depth))
        stack.extend((grandchild, depth + 1) for grandchild in children.get(child, []))
    return found


def pi_session_dir_for_cwd(cwd: str) -> Path:
    encoded = "--" + cwd.strip("/").replace("/", "-") + "--"
    return PI_SESSION_ROOT / encoded


def pi_sessions_for_cwd(cwd: str) -> list[str]:
    session_dir = pi_session_dir_for_cwd(cwd)
    try:
        sessions = [p for p in session_dir.glob("*.jsonl") if p.is_file()]
    except Exception:
        return []
    return [str(p) for p in sorted(sessions, key=lambda p: p.stat().st_mtime, reverse=True)]


def latest_pi_session_for_cwd(cwd: str) -> str:
    sessions = pi_sessions_for_cwd(cwd)
    return sessions[0] if sessions else ""


def pi_title_label(title: str) -> str:
    title = title.strip()
    if not title.lower().startswith("pi - "):
        return ""
    label = title[5:].split(":", 1)[0].strip().lower()
    return label


def pi_session_cwd(session: str) -> str:
    try:
        with Path(session).open(errors="ignore") as handle:
            first = handle.readline()
        meta = json.loads(first)
        cwd = meta.get("cwd") or (meta.get("payload") or {}).get("cwd") or ""
        return cwd if cwd and Path(cwd).is_dir() else ""
    except Exception:
        return ""


def pi_sessions_matching_label(label: str) -> list[str]:
    if not label or not PI_SESSION_ROOT.exists():
        return []
    matches: list[Path] = []
    needle = label.lower()
    try:
        session_dirs = [p for p in PI_SESSION_ROOT.iterdir() if p.is_dir()]
    except Exception:
        return []
    home_prefix = "--" + str(Path.home()).strip("/").replace("/", "-")
    for session_dir in session_dirs:
        name = session_dir.name.lower()
        if not name.startswith(home_prefix.lower()) or needle not in name:
            continue
        try:
            matches.extend(p for p in session_dir.glob("*.jsonl") if p.is_file())
        except Exception:
            continue
    return [str(p) for p in sorted(matches, key=lambda p: p.stat().st_mtime, reverse=True)]


def legacy_pi_session_candidates(win: dict) -> list[str]:
    """Best-effort Pi session candidates for old saves lacking agentSession.

    Alacritty support was added after some session files were already saved, so
    those records only have the title/cwd. Prefer exact cwd sessions except when
    the saved cwd is the home directory and the title names a project; in that
    common case the terminal process cwd was generic but the Pi title still has
    the useful project label.
    """
    title = win.get("title") or ""
    label = pi_title_label(title)
    if not label:
        return []

    workdir = win.get("restoreWorkdir") or ""
    home = str(Path.home())
    cwd_sessions = pi_sessions_for_cwd(workdir) if workdir else []
    title_sessions = pi_sessions_matching_label(label)
    basename = Path(workdir).name.lower() if workdir else ""

    ordered: list[str] = []
    if workdir == home and label != basename:
        ordered.extend(title_sessions)
        ordered.extend(cwd_sessions)
    else:
        ordered.extend(cwd_sessions)
        if not cwd_sessions:
            ordered.extend(title_sessions)

    return list(dict.fromkeys(ordered))


def choose_unused_session(tool: str, sessions: list[str], used_sessions: dict[str, set[str]]) -> str:
    used = used_sessions.setdefault(tool, set())
    for session in sessions:
        if session not in used:
            used.add(session)
            return session
    if sessions:
        # If every candidate is already consumed, keep a deterministic fallback
        # but still return a usable session rather than dropping resume support.
        return sessions[0]
    return ""


def claude_project_dir_for_cwd(cwd: str, project_root: Path = CLAUDE_PROJECT_ROOT) -> Path:
    # Claude Code stores sessions by cwd with non-alphanumeric characters
    # replaced by '-': /home/me/src/foo.bar -> -home-me-src-foo-bar.
    return project_root / re.sub(r"[^A-Za-z0-9]", "-", cwd)


def latest_claude_session_for_cwd(cwd: str, project_root: Path = CLAUDE_PROJECT_ROOT) -> str:
    session_dir = claude_project_dir_for_cwd(cwd, project_root)
    try:
        sessions = [p for p in session_dir.glob("*.jsonl") if p.is_file()]
    except Exception:
        return ""
    if not sessions:
        return ""
    return max(sessions, key=lambda p: p.stat().st_mtime).stem


def claude_project_root_from_env(env: dict[str, str]) -> Path:
    config_dir = env.get("CLAUDE_CONFIG_DIR") or ""
    if config_dir:
        return Path(config_dir) / "projects"
    return CLAUDE_PROJECT_ROOT


def claude_command_from_env(env: dict[str, str]) -> str:
    config_dir = (env.get("CLAUDE_CONFIG_DIR") or "").rstrip("/")
    profile = Path(config_dir).name if config_dir else ""
    if profile in CLAUDE_ALIAS_CONFIGS:
        return CLAUDE_ALIAS_CONFIGS[profile]

    base_url = (env.get("ANTHROPIC_BASE_URL") or "").lower()
    if "deepseek" in base_url:
        return "clod"
    if "cliproxy" in base_url or "cli-proxy" in base_url:
        return "cloc"

    # Local Claude Code should be restored through the user's normal wrapper.
    # The `clo` wrapper clears provider overrides before execing `claude`, which
    # avoids reopening a provider-specific session with the wrong credentials.
    return "clo"


def latest_codex_session_for_cwd(cwd: str) -> str:
    try:
        sessions = [p for p in CODEX_SESSION_ROOT.rglob("*.jsonl") if p.is_file()]
    except Exception:
        return ""
    best: tuple[float, str] = (0, "")
    for path in sessions:
        try:
            first = path.open(errors="ignore").readline()
            meta = json.loads(first)
            payload = meta.get("payload") or {}
            if payload.get("cwd") != cwd:
                continue
            session_id = payload.get("id") or ""
            if not session_id:
                continue
            mtime = path.stat().st_mtime
            if mtime > best[0]:
                best = (mtime, session_id)
        except Exception:
            continue
    return best[1]


def latest_opencode_session_for_cwd(cwd: str) -> str:
    if not OPENCODE_DB.exists():
        return ""
    try:
        with sqlite3.connect(f"file:{OPENCODE_DB}?mode=ro", uri=True) as conn:
            row = conn.execute(
                """
                select id from session
                where directory = ? or path = ?
                order by time_updated desc
                limit 1
                """,
                (cwd, cwd),
            ).fetchone()
    except Exception:
        return ""
    return row[0] if row else ""


def make_restore_argv(argv: list[str]) -> list[str]:
    if not argv or Path(argv[0]).name not in {"make", "gmake"}:
        return []
    for arg in argv[1:]:
        if arg.startswith("-") or "=" in arg:
            continue
        if arg in MAKE_RESTORE_TARGETS:
            return argv
    return []


def terminal_child_state(pid: int, fallback: str, children: dict[int, list[int]], used_sessions: dict[str, set[str]]) -> tuple[str, list[str], dict]:
    home = str(Path.home())
    best = (0, fallback)
    restore_argv: list[str] = []
    restore_session: dict = {}
    kids = sorted(descendants(pid, children), key=lambda item: item[1])

    # Prefer exact local agent resumes when the tool exposes a stable resume
    # mechanism. This beats rerunning `make claude`/`make codex` because it opens
    # the saved conversation instead of starting a fresh one.
    for child_pid, depth in kids:
        cwd = read_proc_cwd(child_pid)
        if not cwd:
            continue
        argv = read_proc_argv(child_pid)
        exe = Path(argv[0]).name if argv else ""

        if exe == "pi":
            sessions = pi_sessions_for_cwd(cwd)
            session = choose_unused_session("pi", sessions, used_sessions)
            if session:
                return cwd, ["pi", "--session", session], {"tool": "pi", "id": session, "path": session, "match": "cwd-newest-unused"}
            return cwd, ["pi", "--continue"], {"tool": "pi", "id": "latest", "match": "continue"}

        if exe == "claude" or exe in CLAUDE_ALIAS_COMMANDS:
            env = read_proc_environ(child_pid)
            command = exe if exe in CLAUDE_ALIAS_COMMANDS else claude_command_from_env(env)
            project_root = claude_project_root_from_env(env)
            session = latest_claude_session_for_cwd(cwd, project_root)
            if session:
                return cwd, [command, "--resume", session], {
                    "tool": "claude",
                    "id": session,
                    "command": command,
                    "projectRoot": str(project_root),
                }
            return cwd, [command, "--continue"], {
                "tool": "claude",
                "id": "latest",
                "command": command,
                "projectRoot": str(project_root),
            }

        if exe == "codex":
            session = latest_codex_session_for_cwd(cwd)
            if session:
                return cwd, ["codex", "resume", session], {"tool": "codex", "id": session}
            return cwd, ["codex", "resume", "--last"], {"tool": "codex", "id": "latest"}

        if exe == "opencode":
            session = latest_opencode_session_for_cwd(cwd)
            if session:
                # OpenCode's session store exposes stable ses_* IDs. Some
                # versions accept --session; if a future/older wrapper rejects
                # it, fall back to plain opencode in the saved directory.
                cmd = f"opencode --session {shlex.quote(session)} || opencode"
                return cwd, ["sh", "-lc", cmd], {"tool": "opencode", "id": session}
            return cwd, ["opencode"], {"tool": "opencode", "id": "latest"}

    # Otherwise preserve the user's wrapper command for known interactive Make
    # targets. This keeps workflows like `make ssh` and remote `make pi N=docs`
    # intact instead of trying to reverse-engineer their long child commands.
    for child_pid, depth in kids:
        cwd = read_proc_cwd(child_pid)
        if not cwd:
            continue
        argv = read_proc_argv(child_pid)
        make_argv = make_restore_argv(argv)
        if make_argv:
            return cwd, make_argv, {}

    for child_pid, depth in kids:
        cwd = read_proc_cwd(child_pid)
        if not cwd:
            continue
        argv = read_proc_argv(child_pid)
        exe = Path(argv[0]).name if argv else ""
        cmd = " ".join(argv)

        if exe in DIRECT_RESTORE_COMMANDS and argv:
            restore_argv = argv
            restore_session = {}
            best = (900 - depth, cwd)
            continue

        score = depth
        if cwd != fallback:
            score += 10
        if cwd != home:
            score += 10
        if exe in {"nvim", "vim", "node", "python", "python3", "bash", "zsh", "fish"}:
            score += 4
        if " pi" in cmd:
            score += 6
        if score > best[0]:
            best = (score, cwd)

    return best[1], restore_argv, restore_session


def raw_clients() -> list[dict]:
    raw = subprocess.check_output(["hyprctl", "clients", "-j"], text=True)
    return json.loads(raw)


def raw_monitors() -> list[dict]:
    try:
        raw = subprocess.check_output(["hyprctl", "monitors", "-j"], text=True)
        return json.loads(raw)
    except Exception:
        return []


def monitor_name_by_id() -> dict[int, str]:
    return {m.get("id"): m.get("name") for m in raw_monitors() if m.get("name") is not None}


def collect_windows() -> list[dict]:
    require("hyprctl")
    clients = raw_clients()
    windows = []
    proc_children = child_map()
    monitors = monitor_name_by_id()
    used_sessions: dict[str, set[str]] = {}

    for c in clients:
        cls = c.get("class") or ""
        if not cls or cls.lower() in EXCLUDED_CLASSES:
            continue
        pid = c.get("pid") or 0
        cwd, cmdline, workdir, argv = proc_info(pid)
        restore_argv: list[str] = []
        restore_session: dict = {}
        if cls.lower() in TERMINAL_CLASSES:
            workdir, restore_argv, restore_session = terminal_child_state(pid, workdir, proc_children, used_sessions)
        ws = c.get("workspace") or {}
        grouped = c.get("grouped") or []
        group_index = grouped.index(c.get("address")) if c.get("address") in grouped else 0
        windows.append({
            "address": c.get("address"),
            "class": cls,
            "initialClass": c.get("initialClass"),
            "title": c.get("title") or "",
            "initialTitle": c.get("initialTitle"),
            "pid": pid,
            "workspace": {"id": ws.get("id"), "name": ws.get("name")},
            "monitor": c.get("monitor"),
            "monitorName": monitors.get(c.get("monitor"), ""),
            "grouped": grouped,
            "groupIndex": group_index,
            "groupSize": len(grouped),
            "floating": c.get("floating"),
            "fullscreen": c.get("fullscreen"),
            "size": c.get("size"),
            "at": c.get("at"),
            "procCwd": cwd,
            "procCmdline": cmdline,
            "procArgv": argv,
            "restoreWorkdir": workdir,
            "restoreArgv": restore_argv,
            "agentSession": restore_session,
            "piSession": restore_session.get("path", "") if restore_session.get("tool") == "pi" else "",
        })

    windows.sort(key=lambda w: (w.get("workspace", {}).get("id") or 0, w.get("class") or "", w.get("title") or ""))
    return windows


def clean_name(name: str) -> str:
    cleaned = "".join(ch for ch in name.strip() if ch.isalnum() or ch in "._-")
    if not cleaned:
        print(f"Invalid session name: {name!r}", file=sys.stderr)
        sys.exit(1)
    return cleaned


def session_path(name: str | None = None) -> Path:
    if not name or name in {"default", "last"}:
        return SESSION_FILE
    if name in {"autosave", "latest-autosave", "latest"}:
        return LATEST_AUTOSAVE
    return PROFILE_DIR / f"{clean_name(name)}.json"


def active_session_snapshot(windows: list[dict]) -> dict:
    active = active_window()
    address = active.get("address") or ""
    matched = next((w for w in windows if w.get("address") == address), {})
    workspace = active.get("workspace") or matched.get("workspace") or {}
    grouped = active.get("grouped") or matched.get("grouped") or []
    group_index = grouped.index(address) if address in grouped else matched.get("groupIndex", 0)
    return {
        "address": address,
        "class": active.get("class") or matched.get("class") or "",
        "title": active.get("title") or matched.get("title") or "",
        "workspace": {"id": workspace.get("id"), "name": workspace.get("name")},
        "monitor": active.get("monitor"),
        "grouped": grouped,
        "groupIndex": group_index,
        "restoreKey": restore_key(matched) if matched else "",
    }


def human_path(path: Path | str) -> str:
    text = str(path)
    home = str(Path.home())
    if text == home:
        return "~"
    if text.startswith(home + "/"):
        return "~" + text[len(home):]
    return text


def plural(count: int, singular: str, plural_word: str | None = None) -> str:
    word = singular if count == 1 else (plural_word or f"{singular}s")
    return f"{count} {word}"


def session_summary(windows: list[dict]) -> str:
    workspaces = {workspace_spec(w) for w in windows if workspace_spec(w) != "0"}
    grouped = {tuple(w.get("grouped") or []) for w in windows if len(w.get("grouped") or []) > 1}
    terminal_resumes = sum(
        1 for w in windows
        if lc_class(w) in TERMINAL_CLASSES and (w.get("restoreArgv") or (w.get("agentSession") or {}).get("id"))
    )
    parts = [plural(len(windows), "window")]
    if workspaces:
        parts.append(f"across {plural(len(workspaces), 'workspace')}")
    if terminal_resumes:
        parts.append(plural(terminal_resumes, "terminal resume"))
    if grouped:
        parts.append(plural(len(grouped), "group"))
    return ", ".join(parts)


def session_file_summary(path: Path) -> str:
    if not path.exists() and not path.is_symlink():
        return "missing"
    try:
        data = json.loads(path.read_text())
        return f"{session_summary(data.get('windows', []))}, {file_age(path)}"
    except Exception:
        return "unreadable"


def write_session(path: Path, *, quiet: bool = False) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    windows = collect_windows()
    data = {
        "savedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "host": os.environ.get("HOSTNAME", ""),
        "activeWindow": active_session_snapshot(windows),
        "windows": windows,
    }
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n")
    tmp.replace(path)
    if not quiet:
        target = f" ({human_path(path)})" if VERBOSE else ""
        print(f"Saved {session_summary(data['windows'])}{target}")
        notify("Omarchy session saved", f"{len(data['windows'])} windows saved")


def cleanup_autosaves(keep: int = AUTOSAVE_KEEP) -> None:
    if not AUTOSAVE_DIR.exists():
        return
    snapshots = sorted(p for p in AUTOSAVE_DIR.glob("*.json") if p.name != "latest.json")
    for old in snapshots[:-keep]:
        try:
            old.unlink()
        except FileNotFoundError:
            pass


def autosave_once(*, quiet: bool = False) -> Path:
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S", time.localtime())
    path = AUTOSAVE_DIR / f"{timestamp}.json"
    write_session(path, quiet=quiet)
    try:
        tmp_latest = LATEST_AUTOSAVE.with_suffix(".tmp")
        if tmp_latest.exists() or tmp_latest.is_symlink():
            tmp_latest.unlink()
        tmp_latest.symlink_to(path.name)
        tmp_latest.replace(LATEST_AUTOSAVE)
    except Exception:
        # Fall back to a real file if symlinks/replace fail for any reason.
        shutil.copy2(path, LATEST_AUTOSAVE)
    cleanup_autosaves()
    return path


def autosave_loop() -> None:
    lock = STATE_DIR / "autosave-loop.pid"
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if lock.exists():
        try:
            old_pid = int(lock.read_text().strip())
            os.kill(old_pid, 0)
            if is_autosave_loop_pid(old_pid):
                print(f"Autosave loop already running as PID {old_pid}")
                return
            print(f"Removing stale autosave pid file for PID {old_pid} (not autosave-loop)")
            lock.unlink()
        except Exception:
            try:
                lock.unlink()
            except FileNotFoundError:
                pass
    lock.write_text(str(os.getpid()))
    try:
        while True:
            path = autosave_once(quiet=True)
            print(f"Autosaved session to {path}", flush=True)
            time.sleep(3600)
    finally:
        try:
            if lock.read_text().strip() == str(os.getpid()):
                lock.unlink()
        except Exception:
            pass


def list_autosaves() -> None:
    if not AUTOSAVE_DIR.exists():
        print(f"No autosaves found at {human_path(AUTOSAVE_DIR)}")
        return
    for path in sorted(AUTOSAVE_DIR.glob("*.json")):
        marker = " -> latest" if path.resolve() == LATEST_AUTOSAVE.resolve() else ""
        if path.name == "latest.json":
            continue
        label = human_path(path) if VERBOSE else path.stem
        print(f"{label}: {session_file_summary(path)}{marker}")


def load_session(path: Path) -> dict:
    if not path.exists():
        print(f"No saved session found at {path}", file=sys.stderr)
        sys.exit(1)
    return json.loads(path.read_text())


def lc_class(win: dict) -> str:
    return (win.get("class") or "").lower()


def normalized_proc_argv(win: dict) -> list[str]:
    argv = win.get("procArgv") or []
    if isinstance(argv, str):
        argv = [argv]
    argv = [str(part) for part in argv]

    # Some browser app windows expose their process cmdline as one space-joined
    # string in /proc/<pid>/cmdline. Split that legacy/surprising shape back
    # into arguments so --app/--user-data-dir can still be restored.
    if len(argv) == 1 and " " in argv[0]:
        try:
            argv = shlex.split(argv[0])
        except ValueError:
            argv = []
    if not argv and win.get("procCmdline"):
        try:
            argv = shlex.split(win.get("procCmdline") or "")
            if len(argv) == 1 and " " in argv[0]:
                argv = shlex.split(argv[0])
        except ValueError:
            argv = []

    # Repair the common unquoted Chromium form "--profile-directory=Profile 3"
    # after splitting a single space-joined command string.
    repaired: list[str] = []
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg.startswith("--profile-directory=") and i + 1 < len(argv) and not argv[i + 1].startswith("--"):
            arg = f"{arg} {argv[i + 1]}"
            i += 1
        repaired.append(arg)
        i += 1
    return repaired


def chrome_app_url_from_class(cls: str) -> str:
    match = re.match(r"^chrome-([^_]+)__-", cls.lower())
    if not match:
        return ""
    host = match.group(1).strip("-.")
    if "." not in host:
        return ""
    return f"https://{host}/"


def url_host(url: str) -> str:
    try:
        return (urlparse(url).netloc or "").lower().removeprefix("www.")
    except Exception:
        return ""


def chrome_app_flags_from_class(cls: str) -> list[str]:
    match = re.match(r"^chrome-[^_]+__-(.+)$", cls)
    if not match:
        return []
    profile = match.group(1).strip()
    if not profile:
        return []
    return [f"--profile-directory={profile}"]


def browser_app_args(win: dict) -> tuple[str, list[str]]:
    argv = normalized_proc_argv(win)
    raw_class = win.get("class") or ""
    cls = raw_class.lower()
    class_url = chrome_app_url_from_class(cls)

    url = ""
    flags: list[str] = []
    keep_prefixes = ("--profile-directory=", "--user-data-dir=", "--class=", "--name=")
    keep_words = {"--profile-directory", "--user-data-dir", "--class", "--name"}
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg.startswith("--app="):
            url = arg.split("=", 1)[1]
        elif arg == "--app" and i + 1 < len(argv):
            url = argv[i + 1]
            i += 1
        elif arg.startswith(keep_prefixes):
            flags.append(arg)
        elif arg in keep_words and i + 1 < len(argv):
            flags.extend([arg, argv[i + 1]])
            i += 1
        i += 1

    # A plain browser class (e.g. "chromium") is a regular browser window, not
    # a web app. Its procCmdline can still contain --app=... when it was spawned
    # by a Chromium master process that was originally launched as a web app;
    # ignore that inherited flag so we relaunch a regular browser window.
    if not class_url and cls in SINGLETON_CLASSES:
        return "", []

    # Chromium web-app windows can all point at the browser's primary process,
    # so proc argv may describe a different web app. Prefer the Hyprland class
    # when the host disagrees; it is generated from the actual app window.
    if class_url and (not url or url_host(url) != url_host(class_url)):
        url = class_url
        if not any(flag.startswith("--user-data-dir") for flag in flags):
            flags = chrome_app_flags_from_class(raw_class)
    return url, flags


def is_webapp(win: dict) -> bool:
    return bool(browser_app_args(win)[0])


def is_singleton(win: dict) -> bool:
    return lc_class(win) in SINGLETON_CLASSES and not is_webapp(win)


def workspace_spec(win: dict) -> str:
    ws = win.get("workspace") or {}
    name = ws.get("name") or ""
    wid = ws.get("id")
    if name.startswith("special:"):
        return name
    if isinstance(wid, int) and wid < 0:
        return name or "special:scratchpad"
    return str(wid or 1)


def is_special_workspace(win: dict) -> bool:
    return workspace_spec(win).startswith("special:")


def restore_key(win: dict) -> str:
    cls = lc_class(win)
    webapp_url, webapp_flags = browser_app_args(win)
    ws = workspace_spec(win)
    if webapp_url:
        return f"ws:{ws}|webapp:{webapp_url}|flags:{' '.join(webapp_flags)}"
    if cls in SINGLETON_CLASSES:
        return f"app:{cls}"
    workdir = win.get("restoreWorkdir") or ""
    if cls in TERMINAL_CLASSES:
        agent = win.get("agentSession") or {}
        if agent.get("tool") and agent.get("id") and agent.get("id") != "latest":
            return f"ws:{ws}|class:{cls}|agent:{agent.get('tool')}:{agent.get('id')}"
        return f"ws:{ws}|class:{cls}|dir:{workdir}"
    return f"ws:{ws}|class:{cls}"


def uwsm_cmd(cmd: list[str]) -> list[str]:
    if shutil.which("uwsm"):
        return ["uwsm", "app", "--", *cmd]
    return cmd


def hypr(*args: str, retries: int = 1, delay: float = 0.08) -> bool:
    for attempt in range(retries + 1):
        try:
            result = subprocess.run(["hyprctl", *args], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            if result.returncode == 0:
                return True
        except Exception:
            pass
        if attempt < retries:
            time.sleep(delay)
    return False


def hypr_exec_on_workspace(cmd: list[str], ws: str) -> bool:
    # Hyprland exec rules launch on the target workspace without switching your
    # current focus there. This avoids restore yanking you around.
    rule = f"[workspace {ws} silent] " if ws else ""
    return hypr("dispatch", "exec", rule + shlex.join(uwsm_cmd(cmd)), retries=2)


def monitor_target(win: dict) -> str:
    name = win.get("monitorName") or ""
    if name:
        return str(name)
    monitor = win.get("monitor")
    if isinstance(monitor, int):
        return str(monitor)
    return ""


def workspace_monitor_moves(targets: list[dict]) -> list[tuple[str, str]]:
    available_names = {m.get("name") for m in raw_monitors() if m.get("name")}
    moves: list[tuple[str, str]] = []
    seen: set[tuple[str, str]] = set()
    for win in targets:
        ws = workspace_spec(win)
        if not ws or ws.startswith("special:"):
            continue
        monitor = monitor_target(win)
        if not monitor:
            continue
        if available_names and not monitor.isdigit() and monitor not in available_names:
            continue
        key = (ws, monitor)
        if key in seen:
            continue
        seen.add(key)
        moves.append(key)
    return moves


def restore_workspace_monitors(targets: list[dict]) -> tuple[int, int]:
    moved = 0
    failed = 0
    for ws, monitor in workspace_monitor_moves(targets):
        if hypr("dispatch", "moveworkspacetomonitor", f"{ws} {monitor}", retries=2):
            moved += 1
        else:
            failed += 1
    return moved, failed


def find_new_window(target: dict, before_addresses: set[str], timeout: float = 6.0) -> dict | None:
    deadline = time.time() + timeout
    target_key = restore_key(target)
    while time.time() < deadline:
        try:
            for win in collect_windows():
                if (win.get("address") or "") in before_addresses:
                    continue
                if restore_key(win) == target_key or lc_class(win) == lc_class(target):
                    return win
        except Exception:
            pass
        time.sleep(0.2)
    return None


def apply_saved_state(target: dict, before_addresses: set[str]) -> tuple[str, int]:
    win = find_new_window(target, before_addresses)
    if not win:
        return "", 0
    address = win.get("address") or ""
    if not address:
        return "", 0
    before_addresses.add(address)
    failed_dispatches = 0

    ws = workspace_spec(target)
    if ws.startswith("special:"):
        if not hypr("dispatch", "movetoworkspacesilent", f"{ws},address:{address}", retries=2):
            failed_dispatches += 1
        return address, failed_dispatches

    # Best-effort: geometry restore is useful mostly for floating windows. Tiled
    # windows are intentionally left to Hyprland's layout. Avoid focuswindow here
    # so restore does not steal focus.
    if target.get("floating"):
        if not hypr("dispatch", "setfloating", f"address:{address}", retries=2):
            failed_dispatches += 1
        size = target.get("size") or []
        at = target.get("at") or []
        if len(size) == 2 and not hypr("dispatch", "resizewindowpixel", f"exact {size[0]} {size[1]},address:{address}", retries=2):
            failed_dispatches += 1
        if len(at) == 2 and not hypr("dispatch", "movewindowpixel", f"exact {at[0]} {at[1]},address:{address}", retries=2):
            failed_dispatches += 1
    return address, failed_dispatches


def active_window() -> dict:
    try:
        raw = subprocess.check_output(["hyprctl", "activewindow", "-j"], text=True)
        return json.loads(raw)
    except Exception:
        return {}


def window_group(address: str) -> list[str]:
    try:
        for win in raw_clients():
            if win.get("address") == address:
                return win.get("grouped") or []
    except Exception:
        pass
    return []


def addresses_same_group(addresses: list[str]) -> bool:
    wanted = set(addresses)
    if len(wanted) < 2:
        return True
    for address in wanted:
        grouped = set(window_group(address))
        if wanted.issubset(grouped):
            return True
    return False


def assign_current_addresses(targets: list[dict], current: list[dict] | None = None) -> dict[str, str]:
    """Map saved Hyprland addresses to current ones after restore.

    Addresses change after reboot, so this uses stable restore keys and then
    falls back to workspace/class/title matching. It is only used for best-effort
    Hyprland group/tab restoration.
    """
    if current is None:
        current = collect_windows()
    used: set[str] = set()
    assigned: dict[str, str] = {}

    current_by_address = {w.get("address"): w for w in current if w.get("address")}
    for target in targets:
        saved_address = target.get("address") or ""
        if saved_address and saved_address in current_by_address and saved_address not in used:
            assigned[saved_address] = saved_address
            used.add(saved_address)

    def pick(target: dict, candidates: list[dict]) -> str:
        title = target.get("title") or ""
        for candidate in candidates:
            addr = candidate.get("address") or ""
            if addr not in used and (candidate.get("title") or "") == title:
                return addr
        for candidate in candidates:
            addr = candidate.get("address") or ""
            if addr not in used:
                return addr
        return ""

    for target in targets:
        saved_address = target.get("address") or ""
        if not saved_address or saved_address in assigned:
            continue
        key = restore_key(target)
        addr = pick(target, [w for w in current if restore_key(w) == key])
        if not addr:
            ws = workspace_spec(target)
            cls = lc_class(target)
            addr = pick(target, [w for w in current if workspace_spec(w) == ws and lc_class(w) == cls])
        if addr:
            assigned[saved_address] = addr
            used.add(addr)

    return assigned


def wait_for_same_group(addresses: list[str], timeout: float = 0.45, interval: float = 0.09) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        if addresses_same_group(addresses):
            return True
        time.sleep(interval)
    return addresses_same_group(addresses)


def group_addresses(addresses: list[str]) -> bool:
    if len(addresses) < 2 or addresses_same_group(addresses):
        return True

    first = addresses[0]
    if len(window_group(first)) < 2:
        if not hypr("dispatch", "focuswindow", f"address:{first}", retries=2):
            return False
        if not hypr("dispatch", "togglegroup", retries=2):
            return False
        wait_for_same_group([first], timeout=0.12)

    # Hyprland's moveintogroup is directional. Restored windows are normally on
    # the same workspace, so try all directions and stop as soon as the target
    # joins the first window's group. This is best-effort and leaves focus
    # restored by restore_groups().
    for address in addresses[1:]:
        if addresses_same_group([first, address]):
            continue
        if not hypr("dispatch", "focuswindow", f"address:{address}", retries=2):
            return False
        for direction in ("l", "r", "u", "d"):
            if not hypr("dispatch", "moveintogroup", direction, retries=1):
                continue
            if wait_for_same_group([first, address], timeout=0.24):
                break
    return wait_for_same_group(addresses, timeout=0.45)


def saved_group_addresses(targets: list[dict]) -> list[tuple[str, ...]]:
    groups: list[tuple[str, ...]] = []
    seen: set[tuple[str, ...]] = set()
    for win in targets:
        grouped = tuple(a for a in (win.get("grouped") or []) if a)
        if len(grouped) > 1 and grouped not in seen:
            seen.add(grouped)
            groups.append(grouped)
    return groups


def saved_window_by_address(targets: list[dict]) -> dict[str, dict]:
    return {w.get("address") or "": w for w in targets if w.get("address")}


def group_member_summaries(group: tuple[str, ...], by_address: dict[str, dict]) -> list[str]:
    summaries = []
    for address in group:
        win = by_address.get(address)
        summaries.append(window_summary(win) if win else f"saved address {address} (not in saved windows)")
    return summaries


def group_status_counts(assessments: list[dict], statuses: list[str]) -> Counter:
    counts = Counter(a.get("status", "") for a in assessments)
    for status in statuses:
        counts.setdefault(status, 0)
    return counts


def assess_dry_run_groups(
    targets: list[dict], current_windows: list[dict], planned_actions: dict[str, str]
) -> list[dict]:
    assigned = assign_current_addresses(targets, current_windows)
    by_address = saved_window_by_address(targets)
    assessments: list[dict] = []

    for group in saved_group_addresses(targets):
        missing_metadata = [a for a in group if a not in by_address]
        actions = {a: planned_actions.get(a, "") for a in group if a in by_address}
        missing_actions = [a for a in group if a in by_address and not actions.get(a)]
        assigned_missing = [a for a in group if actions.get(a) == "already_open" and not assigned.get(a)]

        if missing_metadata or missing_actions or assigned_missing:
            status = "cannot_assess"
        elif any(action == "skipped" for action in actions.values()):
            status = "partial_missing"
        elif all(action == "already_open" for action in actions.values()):
            current_addresses = list(dict.fromkeys(assigned[a] for a in group if assigned.get(a)))
            if len(current_addresses) == len(group) and addresses_same_group(current_addresses):
                status = "already_correct"
            else:
                status = "would_regroup"
        else:
            status = "would_regroup"

        assessments.append({
            "group": group,
            "status": status,
            "members": group_member_summaries(group, by_address),
            "missingMetadata": missing_metadata,
            "missingActions": missing_actions,
            "assignedMissing": assigned_missing,
            "actions": actions,
        })

    return assessments


def verify_saved_groups(targets: list[dict], assigned: dict[str, str]) -> list[dict]:
    by_address = saved_window_by_address(targets)
    assessments: list[dict] = []

    for group in saved_group_addresses(targets):
        missing_metadata = [a for a in group if a not in by_address]
        current_addresses = list(dict.fromkeys(assigned[a] for a in group if assigned.get(a)))

        if missing_metadata:
            status = "cannot_assess"
        elif len(current_addresses) < len(group):
            status = "partial_missing"
        elif addresses_same_group(current_addresses):
            status = "correct"
        else:
            status = "failed"

        assessments.append({
            "group": group,
            "status": status,
            "members": group_member_summaries(group, by_address),
            "missingMetadata": missing_metadata,
            "currentAddresses": current_addresses,
        })

    return assessments


def group_status_label(status: str) -> str:
    return {
        "already_correct": "already correct",
        "would_regroup": "would regroup",
        "partial_missing": "partial/missing",
        "cannot_assess": "cannot assess",
    }.get(status, status.replace("_", " "))


def print_verbose_group_details(assessments: list[dict]) -> None:
    if not VERBOSE or not assessments:
        return
    for index, assessment in enumerate(assessments, start=1):
        print(
            f"  group {index}: {group_status_label(assessment['status'])} "
            f"({len(assessment['group'])} saved members)"
        )
        actions = assessment.get("actions") or {}
        if actions:
            action_counts = Counter(actions.values())
            print(
                f"    actions: already open {action_counts.get('already_open', 0)}, "
                f"would launch {action_counts.get('would_launch', 0)}, "
                f"skipped {action_counts.get('skipped', 0)}"
            )
        current_addresses = assessment.get("currentAddresses") or []
        if current_addresses:
            print(f"    current addresses: {', '.join(current_addresses)}")
        missing = (
            (assessment.get("missingMetadata") or [])
            + (assessment.get("missingActions") or [])
            + (assessment.get("assignedMissing") or [])
        )
        if missing:
            print(f"    unresolved saved addresses: {', '.join(dict.fromkeys(missing))}")
        for member in assessment.get("members", []):
            print(f"    - {member}")


def restore_groups(targets: list[dict]) -> tuple[int, dict[str, str]]:
    assigned = assign_current_addresses(targets)
    groups = saved_group_addresses(targets)
    if not groups:
        return 0, assigned

    restored = 0
    for saved_addresses in groups:
        current_addresses = [assigned[a] for a in saved_addresses if a in assigned]
        # Deduplicate while preserving saved group/tab order.
        current_addresses = list(dict.fromkeys(current_addresses))
        if len(current_addresses) < 2 or addresses_same_group(current_addresses):
            continue
        if group_addresses(current_addresses):
            restored += 1

    return restored, assigned


def workspace_from_snapshot(snapshot: dict) -> str:
    ws = snapshot.get("workspace") or {}
    name = ws.get("name") or ""
    wid = ws.get("id")
    if name.startswith("special:"):
        return name
    if isinstance(wid, int) and wid < 0:
        return name or "special:scratchpad"
    return str(wid or "")


def restore_saved_focus(data: dict, targets: list[dict], assigned: dict[str, str], fallback_active: dict) -> tuple[bool, bool]:
    attempted = False
    active = data.get("activeWindow") or {}
    if active:
        saved_address = active.get("address") or ""
        current_address = assigned.get(saved_address, "")
        if not current_address and saved_address:
            try:
                live_addresses = {w.get("address") for w in raw_clients()}
                if saved_address in live_addresses:
                    current_address = saved_address
            except Exception:
                pass
        if current_address:
            attempted = True
            if hypr("dispatch", "focuswindow", f"address:{current_address}", retries=2):
                return True, attempted

        active_key = active.get("restoreKey") or ""
        if active_key:
            for win in collect_windows():
                if restore_key(win) == active_key:
                    address = win.get("address") or ""
                    if address:
                        attempted = True
                        if hypr("dispatch", "focuswindow", f"address:{address}", retries=2):
                            return True, attempted
                        break

        ws = workspace_from_snapshot(active)
        if ws:
            attempted = True
            if hypr("dispatch", "workspace", ws, retries=2):
                return True, attempted

    # Older session files did not record active focus. Preserve the user's
    # pre-restore focus in that case so restore does not yank them around.
    fallback_address = fallback_active.get("address") or ""
    if fallback_address:
        attempted = True
        if hypr("dispatch", "focuswindow", f"address:{fallback_address}", retries=2):
            return True, attempted
    fallback_ws = workspace_from_snapshot(fallback_active)
    if fallback_ws:
        attempted = True
        if hypr("dispatch", "workspace", fallback_ws, retries=2):
            return True, attempted
    return False, attempted


def enrich_legacy_terminal_targets(targets: list[dict]) -> None:
    used_sessions: dict[str, set[str]] = {}
    for win in targets:
        if lc_class(win) not in TERMINAL_CLASSES:
            continue
        if win.get("restoreArgv") or (win.get("agentSession") or {}).get("id"):
            continue
        session = choose_unused_session("pi", legacy_pi_session_candidates(win), used_sessions)
        if session:
            win["restoreArgv"] = ["pi", "--session", session]
            win["agentSession"] = {"tool": "pi", "id": session, "path": session, "match": "legacy-title-cwd"}
            win["piSession"] = session
            session_cwd = pi_session_cwd(session)
            if session_cwd:
                win["restoreWorkdir"] = session_cwd


def terminal_restore_argv(win: dict) -> list[str]:
    restore_argv = win.get("restoreArgv") or []
    if restore_argv:
        return restore_argv

    agent = win.get("agentSession") or {}
    if agent.get("tool") == "pi" and agent.get("path"):
        return ["pi", "--session", agent.get("path")]
    if agent.get("tool") == "claude" and agent.get("command"):
        command = agent.get("command")
        session = agent.get("id") or ""
        if session and session != "latest":
            return [command, "--resume", session]
        return [command, "--continue"]

    # Legacy saves made before a terminal class was supported may still have a
    # useful title but no child-process restore metadata. Reopen the obvious
    # agent in the saved cwd rather than dropping the user into an empty shell.
    title = (win.get("title") or "").strip().lower()
    if title.startswith("pi - "):
        return ["pi"]
    if title.startswith("clod"):
        return ["clod"]
    if title.startswith("cloc"):
        return ["cloc"]
    if title.startswith("clo") or title.startswith("claude"):
        return ["clo"]
    if title.startswith("codex"):
        return ["codex"]
    if title.startswith("opencode"):
        return ["opencode"]
    return []


def terminal_exec_argv(restore_argv: list[str]) -> list[str]:
    if not restore_argv:
        return []

    # Omarchy's Super+Return binding asks `omarchy-cmd-terminal-cwd` for the cwd
    # of the active terminal. That helper intentionally trusts only a direct
    # shell child of the terminal. If we launch `alacritty -e pi --session ...`,
    # the terminal's direct child is `pi`, so Super+Return falls back to $HOME.
    # Keep a shell as the direct child and run the restored command underneath it.
    # The trailing exec also prevents bash from optimizing itself away into the
    # final command, and leaves a useful shell if the restored agent exits.
    return ["bash", "-lc", '"$@"; exec "${SHELL:-/bin/bash}" -l', "omarchy-session-restore", *restore_argv]


def launch_command(win: dict) -> tuple[list[str] | None, str]:
    cls = lc_class(win)
    workdir = win.get("restoreWorkdir") or ""
    webapp_url, webapp_flags = browser_app_args(win)
    cmd: list[str] | None = None

    if webapp_url and shutil.which("omarchy-launch-webapp"):
        cmd = ["omarchy-launch-webapp", webapp_url, *webapp_flags]
    elif cls in {"com.mitchellh.ghostty", "ghostty"}:
        restore_argv = terminal_restore_argv(win)
        cmd = ["ghostty"]
        if workdir and Path(workdir).is_dir():
            cmd.append(f"--working-directory={workdir}")
        if restore_argv:
            cmd.extend(["-e", *terminal_exec_argv(restore_argv)])
    elif cls == "alacritty":
        restore_argv = terminal_restore_argv(win)
        cmd = ["alacritty"]
        if workdir and Path(workdir).is_dir():
            cmd.append(f"--working-directory={workdir}")
        if restore_argv:
            cmd.extend(["-e", *terminal_exec_argv(restore_argv)])
    elif cls in {"chromium", "chromium-browser"}:
        cmd = ["chromium"]
    elif cls in {"brave-browser", "brave"}:
        cmd = ["brave"]
    elif cls in {"google-chrome", "google-chrome-stable"}:
        cmd = ["google-chrome-stable"]
    elif cls in {"firefox", "firefoxdeveloperedition"}:
        cmd = ["firefox"]
    elif cls == "obsidian":
        cmd = ["obsidian"]
    elif cls == "slack":
        cmd = ["slack"]
    elif cls == "discord":
        cmd = ["discord"]
    elif cls in {"signal", "signal-desktop"}:
        cmd = ["signal-desktop"]
    elif cls in {"org.gnome.nautilus", "nautilus"}:
        cmd = ["nautilus", "--new-window"]
    elif cls == "thunderbird":
        cmd = ["thunderbird"]
    elif cls in {"keepassxc", "org.keepassxc.keepassxc"}:
        cmd = ["keepassxc"]
    elif cls in {"code", "code-url-handler", "visual-studio-code"}:
        cmd = ["code", workdir] if workdir and Path(workdir).is_dir() else ["code"]

    if not cmd:
        return None, f"unknown app class: {win.get('class')} — {win.get('title')}"
    if not shutil.which(cmd[0]):
        return None, f"missing command for {win.get('class')}: {cmd[0]}"
    return cmd, ""


def launch_result(win: dict) -> str:
    cmd, skip_reason = launch_command(win)
    if not cmd:
        print(f"Skipping {skip_reason}", file=sys.stderr)
        return "skipped"

    ws = workspace_spec(win)
    if hypr_exec_on_workspace(cmd, ws):
        return "launched"
    if VERBOSE:
        print(f"Launch dispatch failed: {window_summary(win)} -> {shlex.join(cmd)}", file=sys.stderr)
    return "dispatch_failed"


def launch(win: dict) -> bool:
    return launch_result(win) == "launched"


def planned_group_count(targets: list[dict]) -> int:
    return len(saved_group_addresses(targets))


def planned_focus_action(data: dict) -> str:
    active = data.get("activeWindow") or {}
    if not active:
        return "would preserve current focus if possible (session has no saved active window)"
    saved_address = active.get("address") or ""
    if saved_address:
        return f"would focus saved active window if matched: address:{saved_address}"
    active_key = active.get("restoreKey") or ""
    if active_key:
        return f"would focus first window matching saved restore key: {active_key}"
    ws = workspace_from_snapshot(active)
    if ws:
        return f"would switch to saved active workspace: {ws}"
    return "would preserve current focus if possible"


def window_summary(win: dict) -> str:
    title = win.get("title") or ""
    title_part = f" — {title}" if title else ""
    return f"workspace {workspace_spec(win)}: {win.get('class')}{title_part}"


def restore_dry_run(path: Path) -> None:
    data = load_session(path)
    targets = [w for w in data.get("windows", []) if workspace_spec(w) != "0"]
    enrich_legacy_terminal_targets(targets)
    current_windows = collect_windows()
    current_counts = Counter(restore_key(w) for w in current_windows)
    monitor_moves = workspace_monitor_moves(targets)
    launched = 0
    skipped_open = 0
    skipped_unknown = 0
    planned_actions: dict[str, str] = {}

    print(f"Restore dry-run{f' for {human_path(path)}' if VERBOSE else ''}")
    print(f"Saved windows considered: {len(targets)}; current windows: {len(current_windows)}")
    if monitor_moves:
        print("Monitor actions:")
        for ws, monitor in monitor_moves:
            print(f"  would move workspace {ws} to monitor {monitor}")
    else:
        print("Monitor actions: none")

    print("Window actions:")
    if not targets:
        print("  none")
    for win in targets:
        key = restore_key(win)
        label = window_summary(win)
        address = win.get("address") or ""
        if current_counts[key] > 0:
            if not is_singleton(win):
                current_counts[key] -= 1
            skipped_open += 1
            if address:
                planned_actions[address] = "already_open"
            print(f"  already open: {label}")
            continue

        cmd, skip_reason = launch_command(win)
        if cmd:
            launched += 1
            if is_singleton(win) or is_webapp(win):
                current_counts[key] += 1
            if address:
                planned_actions[address] = "would_launch"
            print(f"  would launch: {label} -> {shlex.join(cmd)}")
        else:
            skipped_unknown += 1
            if address:
                planned_actions[address] = "skipped"
            print(f"  skipped: {label} ({skip_reason})")

    group_assessments = assess_dry_run_groups(targets, current_windows, planned_actions)
    group_count = len(group_assessments)
    if group_count:
        counts = group_status_counts(group_assessments, ["already_correct", "would_regroup", "partial_missing", "cannot_assess"])
        print(
            "Group actions: "
            f"{group_count} saved group(s): "
            f"already correct {counts['already_correct']}, "
            f"would regroup {counts['would_regroup']}, "
            f"partial/missing {counts['partial_missing']}, "
            f"cannot assess {counts['cannot_assess']}"
        )
        print_verbose_group_details(group_assessments)
    else:
        print("Group actions: none")
    print(f"Focus actions: {planned_focus_action(data)}")
    monitor_note = f", monitor placements {len(monitor_moves)}" if monitor_moves else ""
    if group_count:
        group_summary = (
            f", saved groups {group_count} "
            f"(already correct {counts['already_correct']}, would regroup {counts['would_regroup']}, "
            f"partial/missing {counts['partial_missing']}, cannot assess {counts['cannot_assess']})"
        )
    else:
        group_summary = ", saved groups 0"
    print(f"Dry-run checked {len(targets)} saved windows: would launch {launched}, already open {skipped_open}, skipped {skipped_unknown}{group_summary}{monitor_note}")


def write_last_restore(source: Path, launched_windows: list[dict]) -> None:
    LAST_RESTORE_FILE.parent.mkdir(parents=True, exist_ok=True)
    data = {
        "restoredAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "source": str(source),
        "launched": launched_windows,
    }
    tmp = LAST_RESTORE_FILE.with_suffix(LAST_RESTORE_FILE.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n")
    tmp.replace(LAST_RESTORE_FILE)


def hard_undo() -> None:
    if not LAST_RESTORE_FILE.exists():
        print(f"No restore launch record found at {LAST_RESTORE_FILE}")
        return
    data = load_session(LAST_RESTORE_FILE)
    launched = data.get("launched") or []
    if not launched:
        print("Last restore did not launch any windows; nothing to close")
        return
    live_addresses = {w.get("address") for w in raw_clients()}
    closed = 0
    missing = 0
    for item in launched:
        address = item.get("address") or ""
        if not address or address not in live_addresses:
            missing += 1
            continue
        hypr("dispatch", "closewindow", f"address:{address}")
        closed += 1
        time.sleep(0.1)
    print(f"Hard undo closed {closed} windows from last restore; missing/already closed {missing}")
    notify("Omarchy hard undo", f"Closed {closed}; missing {missing}")


def restore(path: Path, *, save_undo: bool = True) -> None:
    data = load_session(path)
    targets = [w for w in data.get("windows", []) if workspace_spec(w) != "0"]
    enrich_legacy_terminal_targets(targets)

    if save_undo:
        write_session(UNDO_FILE, quiet=True)
        print(f"Stored pre-restore state{f' at {human_path(UNDO_FILE)}' if VERBOSE else ''}")

    fallback_active = active_window()
    current_windows = collect_windows()
    before_addresses = {w.get("address") or "" for w in current_windows}
    current_counts = Counter(restore_key(w) for w in current_windows)
    monitors_restored, monitor_failures = restore_workspace_monitors(targets)
    launched = 0
    skipped_open = 0
    skipped_unknown = 0
    launch_dispatch_failed = 0
    launched_undetected = 0
    state_dispatch_failed = 0
    groups_restored = 0
    launched_windows: list[dict] = []

    for win in targets:
        key = restore_key(win)
        if current_counts[key] > 0:
            if not is_singleton(win):
                current_counts[key] -= 1
            skipped_open += 1
            continue
        launch_status = launch_result(win)
        if launch_status == "launched":
            launched += 1
            address, dispatch_failures = apply_saved_state(win, before_addresses)
            state_dispatch_failed += dispatch_failures
            if address:
                launched_windows.append({
                    "address": address,
                    "class": win.get("class"),
                    "title": win.get("title"),
                    "workspace": workspace_spec(win),
                    "restoreKey": restore_key(win),
                })
            else:
                launched_undetected += 1
            if is_singleton(win) or is_webapp(win):
                current_counts[key] += 1
            time.sleep(0.35)
        elif launch_status == "dispatch_failed":
            launch_dispatch_failed += 1
        else:
            skipped_unknown += 1

    groups_restored, assigned = restore_groups(targets)
    group_assessments = verify_saved_groups(targets, assigned)
    group_count = len(group_assessments)
    if group_count:
        group_counts = group_status_counts(group_assessments, ["correct", "partial_missing", "failed", "cannot_assess"])
        print_verbose_group_details(group_assessments)
        group_note = (
            f", groups actively restored {groups_restored}, "
            f"groups verified correct {group_counts['correct']}/{group_count}, "
            f"partial/missing {group_counts['partial_missing']}, "
            f"failed {group_counts['failed']}, "
            f"cannot assess {group_counts['cannot_assess']}"
        )
    else:
        group_counts = Counter()
        group_note = ", saved groups 0"
    focus_restored, focus_attempted = restore_saved_focus(data, targets, assigned, fallback_active)
    if focus_restored:
        focus_note = ", focus restored"
    elif focus_attempted:
        focus_note = ", focus restore failed"
    else:
        focus_note = ""
    write_last_restore(path, launched_windows)
    monitor_parts = []
    if monitors_restored:
        monitor_parts.append(f"monitor placements {monitors_restored}")
    if monitor_failures:
        monitor_parts.append(f"monitor placement failures {monitor_failures}")
    monitor_note = f", {', '.join(monitor_parts)}" if monitor_parts else ""
    launch_note = ""
    launch_issues = []
    if launch_dispatch_failed:
        launch_issues.append(f"launch dispatch failed {launch_dispatch_failed}")
    if launched_undetected:
        launch_issues.append(f"launched undetected {launched_undetected}")
    if state_dispatch_failed:
        launch_issues.append(f"state dispatch failures {state_dispatch_failed}")
    if launch_issues:
        launch_note = f", {', '.join(launch_issues)}"
    print(f"Restore checked {len(targets)} saved windows: launched {launched}, already open {skipped_open}, skipped {skipped_unknown}{launch_note}{group_note}{monitor_note}{focus_note}")
    notify("Omarchy session restore", f"Launched {launched}; already open {skipped_open}; groups correct {group_counts.get('correct', 0)}/{group_count}")


def session_choices() -> list[tuple[str, Path]]:
    choices: list[tuple[str, Path]] = [("default", SESSION_FILE)]
    if PROFILE_DIR.exists():
        for path in sorted(PROFILE_DIR.glob("*.json")):
            choices.append((f"profile: {path.stem}", path))
    if LATEST_AUTOSAVE.exists() or LATEST_AUTOSAVE.is_symlink():
        choices.append(("autosave: latest", LATEST_AUTOSAVE))
    if AUTOSAVE_DIR.exists():
        autosaves = sorted((p for p in AUTOSAVE_DIR.glob("*.json") if p.name != "latest.json"), key=lambda p: p.stat().st_mtime, reverse=True)
        for path in autosaves[:20]:
            choices.append((f"autosave: {path.stem}", path))
    return choices


def list_profiles() -> None:
    for label, path in session_choices():
        summary = session_file_summary(path)
        if VERBOSE:
            print(f"{label}\t{summary}\t{human_path(path)}")
        else:
            print(f"{label}: {summary}")


def run_menu(labels: list[str], prompt: str) -> str:
    menu_cmds = [
        ["walker", "--dmenu", "--exit", "--placeholder", prompt],
        ["wofi", "--dmenu", "--prompt", prompt],
        ["fuzzel", "--dmenu", "--prompt", f"{prompt}: "],
        ["rofi", "-dmenu", "-p", prompt],
    ]
    for cmd in menu_cmds:
        if not shutil.which(cmd[0]):
            continue
        try:
            result = subprocess.run(cmd, input="\n".join(labels) + "\n", text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
        except Exception:
            continue
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip().splitlines()[-1]
        if result.returncode != 0:
            return ""

    if sys.stdin.isatty():
        for i, label in enumerate(labels, 1):
            print(f"{i:2d}. {label}")
        answer = input(f"{prompt} [1-{len(labels)}]: ").strip()
        if answer.isdigit() and 1 <= int(answer) <= len(labels):
            return labels[int(answer) - 1]
    else:
        for i, label in enumerate(labels, 1):
            print(f"{i}\t{label}")
    return ""


def pick_session(action: str = "restore") -> None:
    choices = session_choices()
    if not choices:
        print("No sessions found", file=sys.stderr)
        sys.exit(1)
    labels = [label for label, _ in choices]
    picked = run_menu(labels, f"ws {action}")
    if not picked:
        print("No session selected", file=sys.stderr)
        sys.exit(1)
    mapping = dict(choices)
    path = mapping.get(picked)
    if not path:
        print(f"Unknown selection: {picked}", file=sys.stderr)
        sys.exit(1)

    if action in {"restore", "r", "start"}:
        restore(path, save_undo=True)
    elif action in {"list", "l", "show"}:
        list_session(path)
    elif action in {"path", "p"}:
        print(path)
    else:
        print(f"Unsupported pick action: {action}", file=sys.stderr)
        sys.exit(1)


def count_session_windows(path: Path) -> str:
    if not path.exists() and not path.is_symlink():
        return "missing"
    try:
        data = load_session(path)
        return str(len(data.get("windows", [])))
    except Exception:
        return "unreadable"


def file_age(path: Path) -> str:
    if not path.exists() and not path.is_symlink():
        return "missing"
    try:
        seconds = max(0, int(time.time() - path.stat().st_mtime))
    except Exception:
        return "unknown"
    if seconds < 90:
        return f"{seconds}s ago"
    minutes = seconds // 60
    if minutes < 90:
        return f"{minutes}m ago"
    hours = minutes // 60
    if hours < 48:
        return f"{hours}h ago"
    return f"{hours // 24}d ago"


def is_autosave_loop_pid(pid: int) -> bool:
    argv = read_proc_argv(pid)
    joined = " ".join(argv)
    return "omarchy-session" in joined and "autosave-loop" in joined


def autosave_loop_status() -> str:
    pid_file = STATE_DIR / "autosave-loop.pid"
    if not pid_file.exists():
        return "not running (no pid file)"
    try:
        pid = int(pid_file.read_text().strip())
        os.kill(pid, 0)
        if is_autosave_loop_pid(pid):
            return f"running pid {pid}"
        return f"stale pid file ({pid_file}; pid {pid} is not autosave-loop)"
    except Exception:
        return f"stale pid file ({pid_file})"


def modmask_label(modmask: int) -> str:
    parts: list[str] = []
    for bit, name in ((64, "Super"), (1, "Shift"), (4, "Ctrl"), (8, "Alt")):
        if modmask & bit:
            parts.append(name)
    return "+".join(parts)


def session_shortcuts() -> list[str]:
    try:
        raw = subprocess.check_output(["hyprctl", "binds", "-j"], text=True, stderr=subprocess.DEVNULL)
        binds = json.loads(raw)
    except Exception:
        binds = []

    rows: list[tuple[str, str, str]] = []
    for bind in binds:
        arg = bind.get("arg") or ""
        if not re.search(r"(^|\s|/)(omarchy-session|ws|restore-workspace)(\s|$)", arg):
            continue
        key = bind.get("key") or (f"code:{bind.get('keycode')}" if bind.get("keycode") else "")
        combo = "+".join(part for part in (modmask_label(int(bind.get("modmask") or 0)), key) if part)
        description = bind.get("description") or "workspace session"
        rows.append((combo, description, arg))

    if not rows:
        return [
            "  Super+Shift+Alt+R  Save current workspace -> ws s",
            "  Super+Shift+R      Restore saved workspace -> ws r",
        ]

    width = max(len(combo) for combo, _, _ in rows)
    return [f"  {combo:<{width}}  {description} -> {arg}" for combo, description, arg in rows]


def shortcuts_help_block() -> str:
    return "\n".join(session_shortcuts())


def health_status() -> None:
    install = Path(__file__)
    try:
        install = install.resolve()
    except Exception:
        pass
    print("Omarchy session status")
    print(f"  install: {install}")
    print(f"  state:   {STATE_DIR}")
    print(f"  autosave loop: {autosave_loop_status()}")
    print(f"  default save:  {SESSION_FILE} ({count_session_windows(SESSION_FILE)} windows, {file_age(SESSION_FILE)})")
    print(f"  latest autosave: {LATEST_AUTOSAVE} ({count_session_windows(LATEST_AUTOSAVE)} windows, {file_age(LATEST_AUTOSAVE)})")
    print(f"  undo snapshot: {UNDO_FILE} ({count_session_windows(UNDO_FILE)} windows, {file_age(UNDO_FILE)})")
    if LAST_RESTORE_FILE.exists():
        try:
            data = load_session(LAST_RESTORE_FILE)
            launched = len(data.get("launched") or [])
            print(f"  last restore: {launched} launched windows, {file_age(LAST_RESTORE_FILE)}")
        except Exception:
            print(f"  last restore: unreadable ({LAST_RESTORE_FILE})")
    else:
        print("  last restore: missing")
    print("  shortcuts:")
    print(shortcuts_help_block())
    print("  commands: ws s, ws r, ws plan, ws pick, ws a, ws as, ws u, ws undo-hard, ws status, ws deps")


def list_session(path: Path = SESSION_FILE) -> None:
    if not path.exists():
        print(f"No saved session found at {path}")
        return
    data = load_session(path)
    active = data.get("activeWindow") or {}
    active_line = ""
    if active:
        active_line = f"Active: workspace {workspace_from_snapshot(active)} — {active.get('class')} — {active.get('title')}\n"
    file_line = f"File: {human_path(path)}\n" if VERBOSE else ""
    saved_line = f"Saved: {file_age(path)}"
    if VERBOSE and data.get("savedAt"):
        saved_line += f" ({data.get('savedAt')})"
    print(f"{saved_line}\n{file_line}{active_line}")
    for w in data.get("windows", []):
        ws = workspace_spec(w)
        webapp_url, _ = browser_app_args(w)
        suffix = f" [{human_path(w.get('restoreWorkdir'))}]" if VERBOSE and w.get("restoreWorkdir") else ""
        if VERBOSE and w.get("restoreArgv"):
            suffix += f" [restore: {shlex.join(w.get('restoreArgv') or [])}]"
        if VERBOSE and w.get("agentSession"):
            agent = w.get("agentSession") or {}
            suffix += f" [session: {agent.get('tool')} {human_path(agent.get('id') or '')}]"
        if (w.get("groupSize") or 0) > 1:
            suffix += f" [group tab {int(w.get('groupIndex') or 0) + 1}/{w.get('groupSize')}]"
        if w.get("monitorName"):
            suffix += f" [monitor: {w.get('monitorName')}]"
        if webapp_url:
            suffix += f" [webapp: {webapp_url}]"
        print(f"workspace {ws}: {w.get('class')} — {w.get('title')}{suffix}")


def usage() -> None:
    prog = Path(sys.argv[0]).name
    print(f"""Usage: {prog} [-v|--verbose] <command> [name]

Options:
  -v, --verbose  include saved file paths and restore metadata

Short commands:
  s [name]    save
  r [name]    restore only missing windows
  plan [name] dry-run restore plan (no dispatch, launches, writes, notifications, or sleeps)
  l [name]    list
  p           profiles/named setups
  pick        pick a profile/autosave and restore it
  a           autosave now
  as          list autosaves
  u           undo/restore pre-restore state
  uh          hard undo: close windows launched by the last restore
  st          status/health
  deps        dependency check

Full commands still work:
  save [name], restore [--dry-run|--plan] [name], plan [name], dry-run [name], list [name], profiles, pick [restore|list|path], autosave, autosaves, undo, undo-hard, status, deps, path [name]

Current shortcuts:
{shortcuts_help_block()}

Files (shown in normal command output only with -v):
  default:   {human_path(SESSION_FILE)}
  named:     {human_path(PROFILE_DIR)}
  autosaves: {human_path(AUTOSAVE_DIR)}  (keeps latest {AUTOSAVE_KEEP})
""")


def parse_global_flags(args: list[str]) -> list[str]:
    global VERBOSE
    parsed: list[str] = []
    for arg in args:
        if arg in {"--verbose", "-v"}:
            VERBOSE = True
        else:
            parsed.append(arg)
    return parsed


def parse_name_and_restore_flags(args: list[str]) -> tuple[str | None, bool]:
    name: str | None = None
    dry_run = False
    for arg in args:
        if arg in {"--dry-run", "--plan", "-n"}:
            dry_run = True
        elif arg in {"--"}:
            continue
        elif arg.startswith("-"):
            print(f"Unknown option: {arg}", file=sys.stderr)
            sys.exit(2)
        elif name is None:
            name = arg
        else:
            print(f"Unexpected extra argument: {arg}", file=sys.stderr)
            sys.exit(2)
    return name, dry_run


def main() -> None:
    args = parse_global_flags(sys.argv[1:])
    cmd = args[0] if args else ""
    rest = args[1:] if args else []
    aliases = {
        "s": "save",
        "r": "restore",
        "l": "list",
        "p": "profiles",
        "pk": "pick",
        "a": "autosave",
        "al": "autosave-loop",
        "as": "autosaves",
        "u": "undo",
        "uh": "undo-hard",
        "st": "status",
    }
    cmd = aliases.get(cmd, cmd)
    name, dry_run = parse_name_and_restore_flags(rest)
    if cmd == "save":
        write_session(session_path(name))
    elif cmd == "autosave":
        path = autosave_once(quiet=True)
        target = f" ({human_path(path)})" if VERBOSE else ""
        print(f"Autosaved {session_file_summary(path)}{target}")
    elif cmd == "autosave-loop":
        autosave_loop()
    elif cmd in {"restore", "start"}:
        if dry_run:
            restore_dry_run(session_path(name))
        else:
            restore(session_path(name), save_undo=True)
    elif cmd in {"plan", "dry-run"}:
        restore_dry_run(session_path(name))
    elif cmd == "undo":
        restore(UNDO_FILE, save_undo=False)
    elif cmd in {"undo-hard", "hard-undo"}:
        hard_undo()
    elif cmd == "status":
        health_status()
    elif cmd in {"deps", "doctor", "check"}:
        dependency_status()
    elif cmd in {"list", "show"}:
        list_session(session_path(name))
    elif cmd == "list-undo":
        list_session(UNDO_FILE)
    elif cmd in {"profiles", "setups"}:
        list_profiles()
    elif cmd == "pick":
        pick_session(name or "restore")
    elif cmd in {"autosaves", "list-autosaves"}:
        list_autosaves()
    elif cmd == "path":
        print(session_path(name))
    else:
        usage()


if __name__ == "__main__":
    main()
